# ============================================
# FARKETMEZ Backend - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# ⚠️ DO NOT COMMIT .env TO GIT

# Server
PORT=8080
ENV=development

# Database (will be set by Railway or local Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/farketmez?sslmode=disable

# Redis (will be set by Railway or local Docker)
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# JWT
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

# App URLs (will be updated for production)
APP_URL=http://localhost:8080
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Google Places (add when ready)
# GOOGLE_PLACES_API_KEY=
